# ============================================================================
# nanobot-stack configuration
# ============================================================================
# Copy this file to stack.env and adjust to your environment.
# This file is sourced by deploy.sh, update.sh, and rotate-secrets.sh.
#
#   cp stack.env.example stack.env
#   $EDITOR stack.env
#   sudo ./deploy.sh
#
# Lines starting with # are comments. Empty values use the shown defaults.
# ============================================================================

# --------------------------------------------------------------------------
# Domain & subdomains
# --------------------------------------------------------------------------
# Your base domain. Subdomains are derived from it.
DOMAIN="example.com"

# Override individual subdomains if needed (defaults shown).
# NANOBOT_SUBDOMAIN="ai"           # → ai.example.com
# RAG_SUBDOMAIN="rag"              # → rag.example.com
# LANGFUSE_SUBDOMAIN="observability" # → observability.example.com
# WEBUI_SUBDOMAIN="chat"           # → chat.example.com

# Authentik outpost FQDN (for Traefik ForwardAuth middleware).
# AUTHENTIK_OUTPOST_FQDN="auth.example.com"

# --------------------------------------------------------------------------
# System user & paths
# --------------------------------------------------------------------------
# APP_USER="nanobot"
# APP_GROUP="nanobot"
# BASE_DIR="/opt/nanobot-stack"
# QDRANT_DATA_DIR="/var/lib/qdrant"
# QDRANT_CONFIG_DIR="/etc/qdrant"
# TRAEFIK_DYNAMIC_DIR="/etc/traefik/dynamic"
# LANGFUSE_DIR="/opt/docker/langfuse"

# --------------------------------------------------------------------------
# Bind addresses & ports
# --------------------------------------------------------------------------
# All services bind to localhost by default (exposed via Traefik).
# NANOBOT_BIND="127.0.0.1"
# NANOBOT_PORT="18790"
# RAG_BIND="127.0.0.1"
# RAG_PORT="8089"
# QDRANT_BIND="127.0.0.1"
# QDRANT_HTTP_PORT="6333"
# QDRANT_GRPC_PORT="6334"
# LANGFUSE_BIND="127.0.0.1"
# LANGFUSE_WEB_PORT="3300"
# WEBUI_BIND="127.0.0.1"
# WEBUI_PORT="18800"

# --------------------------------------------------------------------------
# Versions & toggles
# --------------------------------------------------------------------------
# Qdrant binary version to install.
# QDRANT_VERSION="v1.17.7"

# Install the optional nanobot-webui.
# INSTALL_NANOBOT_WEBUI="false"

# --------------------------------------------------------------------------
# Default models
# --------------------------------------------------------------------------
# The main nanobot agent model (used in config.json).
# NANOBOT_DEFAULT_MODEL="anthropic/claude-sonnet-4-20250514"

# --------------------------------------------------------------------------
# RAG bridge tuning
# --------------------------------------------------------------------------
# Cross-encoder reranker (set RERANKER_ENABLED=false to use legacy scoring).
# RERANKER_ENABLED="true"
# RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
# RERANKER_DEVICE="cpu"            # "cpu" or "cuda"

# Hybrid search: dense + sparse vectors in Qdrant.
# SPARSE_VECTORS_ENABLED="true"

# Embedding cache.
# EMBEDDING_CACHE_SIZE="512"
# EMBEDDING_CACHE_TTL="3600"
# EMBEDDING_BATCH_SIZE="32"

# Chunking.
# MAX_CHUNK_CHARS="1800"
# CHUNK_OVERLAP="200"

# Search defaults.
# SEARCH_LIMIT="8"
# PREFETCH_MULTIPLIER="4"
# MAX_PREFETCH="24"

# Memory auto-summarisation.
# AUTO_SUMMARIZE_MEMORY="true"
# DEFAULT_ANSWER_TASK="retrieval_answer"

# Rate limiting (token-bucket).
# REMEMBER_RATE_CAPACITY="30"      # burst capacity for /remember
# REMEMBER_RATE_REFILL="0.5"       # tokens/sec refill

# Circuit breaker.
# CB_FAILURE_THRESHOLD="3"
# CB_RECOVERY_TIMEOUT="120"        # seconds

# Logging.
# LOG_LEVEL="INFO"

# --------------------------------------------------------------------------
# Vision / multi-modal ingestion
# --------------------------------------------------------------------------
# Extract images from PDFs/DOCX and generate text descriptions via vision model.
# VISION_ENABLED="true"
# VISION_MAX_IMAGES_PER_DOC="5"
# VISION_MIN_IMAGE_BYTES="5000"

# --------------------------------------------------------------------------
# Tools
# --------------------------------------------------------------------------
# Restricted shell command timeout (seconds).
# SHELL_TIMEOUT="15"

# Web fetch limits.
# WEB_FETCH_TIMEOUT="30"
# WEB_FETCH_MAX_CHARS="15000"

# Notification webhook URL (ntfy.sh, Slack, Telegram bot API, generic JSON).
# NOTIFICATION_WEBHOOK_URL=""

# --------------------------------------------------------------------------
# Feedback loop
# --------------------------------------------------------------------------
# Weight applied to each positive/negative feedback event.
# FEEDBACK_BOOST_WEIGHT="0.1"
# FEEDBACK_MAX_BOOST="0.5"
# FEEDBACK_MIN_BOOST="-0.3"

# --------------------------------------------------------------------------
# Elevated shell (approval-gated mutating commands)
# --------------------------------------------------------------------------
# Allow the agent to propose system-modifying commands (systemctl restart,
# apt install, docker run, etc.) subject to user approval before execution.
# ELEVATED_SHELL_ENABLED="false"
# ELEVATED_SHELL_TIMEOUT="60"         # seconds before command is killed
# ELEVATED_ACTION_EXPIRY="30"         # minutes until pending action expires
# ELEVATED_EXTRA_COMMANDS=""           # JSON object to add commands, e.g. '{"npm": ["install","uninstall"], "snap": true}'
# ELEVATED_DISABLED_COMMANDS=""        # comma-separated binaries to remove from defaults, e.g. "rm,chmod,chown"

# --------------------------------------------------------------------------
# Config writer (approval-gated configuration changes)
# --------------------------------------------------------------------------
# Allow the agent to propose changes to config files (.env, model_router.json,
# policy prompt).  Changes are validated, staged, and diffed for review.
# CONFIG_WRITER_ENABLED="false"
# CONFIG_CHANGE_EXPIRY="60"           # minutes until pending change expires

# --------------------------------------------------------------------------
# Channel adapters (bidirectional messaging)
# --------------------------------------------------------------------------
# DM policy: "pairing" (default) requires server-side approval before a user
# can interact.  "open" allows all inbound messages without approval.
# CHANNEL_DM_POLICY="pairing"
# PAIRING_CODE_EXPIRY="30"            # minutes until pairing code expires
#
# Telegram bot (long-polling, no webhook server needed)
# Create a bot via @BotFather and paste the token here.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_ALLOWED_CHAT_IDS=""        # comma-separated chat IDs; empty = all

# Discord bot (websocket gateway)
# Create an application at https://discord.com/developers and enable
# MESSAGE CONTENT intent.
# DISCORD_BOT_TOKEN=""
# DISCORD_ALLOWED_CHANNEL_IDS=""      # comma-separated; empty = all

# WhatsApp Business Cloud API (webhook-based)
# Requires a Meta Business account and verified phone number.
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_VERIFY_TOKEN=""            # random string for webhook verification
# WHATSAPP_APP_SECRET=""              # for payload signature verification

# --------------------------------------------------------------------------
# Local / offline fallback (Ollama)
# --------------------------------------------------------------------------
# Install Ollama as a local LLM fallback for offline/degraded operation.
# Models are CPU-optimised by default (no GPU required).
# INSTALL_OLLAMA="true"
# OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"
# OLLAMA_API_KEY="ollama"
# OLLAMA_CHAT_MODEL="qwen2.5:7b"           # CPU-friendly, ~4.7GB RAM
# OLLAMA_EMBED_MODEL="nomic-embed-text"     # ~274MB

# --------------------------------------------------------------------------
# Langfuse project bootstrap
# --------------------------------------------------------------------------
# LANGFUSE_INIT_ORG_ID="my-org"
# LANGFUSE_INIT_ORG_NAME="My Organisation"
# LANGFUSE_INIT_PROJECT_ID="nanobot"
# LANGFUSE_INIT_PROJECT_NAME="nanobot"

# --------------------------------------------------------------------------
# SearXNG self-hosted search (Sub-project D)
# --------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
# SEARXNG_SECRET_KEY=""
# SEARXNG_ENABLED="false"
# WEB_SEARCH_RATE_LIMIT_PER_HOUR="30"
# WEB_SEARCH_RESULT_TTL_HOURS="6"
# WEB_DIGEST_TOPICS="intelligence artificielle,kubernetes,docker"
